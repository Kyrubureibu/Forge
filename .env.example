# ─────────────────────────────────────────────
#  Forge — AI Coding Assistant  |  .env.example
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
# The server (proxy) loads these at runtime.
# NEVER commit .env to git.

# ── Server ────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── API Provider (set one or more) ────────────

# OpenRouter  →  https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx

# Hugging Face  →  https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare Workers AI  →  https://dash.cloudflare.com
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# ── CORS (comma-separated allowed origins) ────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

